{
  "name": "alanpetersen-moodle",
  "version": "2.0.0",
  "author": "alanpetersen",
  "summary": "Manages the Moodle Learning Management System",
  "license": "Apache-2.0",
  "source": "https://github.com/alanpetersen/puppet-moodle.git",
  "project_page": "https://github.com/alanpetersen/puppet-moodle",
  "issues_url": "https://github.com/alanpetersen/puppet-moodle/issues",

  "dependencies": [
    {
      "name": "puppetlabs/archive",
      "version_requirement": ">= 6.0.0 < 10.0.0"
    },
    {
      "name": "puppetlabs/mysql",
      "version_requirement": ">= 15.0.0 < 20.0.0"
    }
  ],

  "requirements": [
    {
      "name": "puppet",
      "version_requirement": ">= 7.0.0 < 9.0.0"
    }
  ],

  "operatingsystem_support": [
    {
      "operatingsystem": "Debian",
      "operatingsystemrelease": ["10", "11", "12"]
    },
    {
      "operatingsystem": "Ubuntu",
      "operatingsystemrelease": ["20.04", "22.04", "24.04"]
    },
    {
      "operatingsystem": "RedHat",
      "operatingsystemrelease": ["8", "9"]
    },
    {
      "operatingsystem": "CentOS",
      "operatingsystemrelease": ["7", "8"]
    }
  ],

  "tags": [
    "moodle",
    "lms",
    "education",
    "archive",
    "database",
    "puppet"
  ]
}
